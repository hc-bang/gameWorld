# ────────────────────────────────────────
# 🚫 게임 월드 — Git 제외 목록 (.gitignore)
# ────────────────────────────────────────

# Python 로컬 서버 캐시
__pycache__/
*.py[cod]
*.pyo

# OS 메타파일
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# 에디터 / IDE 설정
.vscode/
.idea/
*.swp
*.swo
*~

# 로그 파일
*.log

# 임시 파일
*.tmp
*.bak
*.orig
